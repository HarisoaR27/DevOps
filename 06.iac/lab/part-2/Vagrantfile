Vagrant.configure("2") do |config|

  config.vm.define "gitlab_server" do |server|

    # Box ARM compatible avec vagrant-qemu
    server.vm.box = "generic/rocky8"

    # Configuration QEMU pour Mac ARM
    server.vm.provider "qemu" do |qe|
      qe.memory = "4G"
      qe.smp = "2"
      qe.ssh_auto_correct = true
      qe.net_device = "virtio-net-device"

      # Partage de dossier via 9p (remplace SMB)
      qe.extra_qemu_args = %w(
        -virtfs local,path=.,mount_tag=shared,security_model=mapped
      )
    end

    # Port pour accéder à GitLab depuis le navigateur
    server.vm.network "forwarded_port",
      guest: 80,
      host: 8080,
      auto_correct: true

    # Désactive SMB
    server.vm.synced_folder ".", "/vagrant", disabled: true

  end

  # Provisioner Ansible local
  config.vm.provision "ansible_local" do |ansible|
    ansible.playbook = "playbooks/run.yml"
    ansible.tags = "install"
  end

end
